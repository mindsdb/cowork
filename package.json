{
  "name": "anton",
  "version": "2.0.4",
  "description": "Anton by MindsDB — autonomous AI coworker",
  "author": "MindsDB",
  "license": "AGPL-3.0-only",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:debug": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron:debug\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite dev src/renderer",
    "dev:electron": "sleep 3 && VITE_DEV=1 electron dist/main/main/index.js",
    "dev:electron:debug": "sleep 3 && VITE_DEV=1 ANTON_OPEN_DEVTOOLS=1 electron dist/main/main/index.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build src/renderer",
    "build:web": "BUILD_TARGET=web vite build src/renderer",
    "dev:web": "node scripts/dev-web.mjs",
    "start": "electron dist/main/main/index.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:unsigned": "bash ./scripts/dist-mac-unsigned.sh",
    "dist:mac:dmg-custom": "bash ./scripts/dist-mac-dmg-custom.sh",
    "release:mac:dmg-custom:notarized": "bash ./scripts/release-mac-custom-notarized.sh",
    "release:mac:pkg:notarized": "bash ./scripts/release-mac-pkg-notarized.sh",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "dist:win:all": "npm run build && electron-builder --win --publish never",
    "release:win:local": "npm run dist:win"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "^6.4.2"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "marked": "^17.0.4",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  }
}
